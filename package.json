{
  "name": "freepdf",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
  "dev:api": "ts-node apps/api/src/app.ts",
  "typecheck": "tsc --noEmit",
  "build": "npm run build:api && npm run build:web && node scripts/prepare-vercel-output.mjs",
  "build:web": "npm run build --workspace freepdf-web",
  "build:api": "tsc",
  "start": "node dist/apps/api/src/app.js"
},
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@supabase/supabase-js": "^2.105.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^10.0.0",
    "bullmq": "^5.76.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19"
  }
}
